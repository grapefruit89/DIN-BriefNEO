{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "ctx7@latest", "mcp"],
      "env": {
        "CONTEXT7_API_KEY": "ctx7sk-5d9fe13d-6578-4b0d-bcd6-eb7cc4b7c187"
      },
      "trust": true
    },
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "trust": true
    },
    "prettier": {
      "command": "npx",
      "args": ["-y", "@prettier/mcp"],
      "trust": true
    },
    "stylelint": {
      "command": "npx",
      "args": ["-y", "stylelint-mcp"],
      "trust": true
    },
    "eslint": {
      "command": "npx",
      "args": ["-y", "@eslint/mcp@latest"],
      "trust": true
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "trust": true
    },
    "accessibility": {
      "command": "npx",
      "args": ["-y", "a11y-mcp"],
      "trust": true
    },
    "typst-mcp": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "ghcr.io/johannesbrandenburger/typst-mcp:latest"],
      "trust": true
    }
  }
}